# ── Core ──────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=CHANGE_ME_generate_with_python3_secrets_token_hex_32
JWT_SECRET_KEY=CHANGE_ME_generate_with_python3_secrets_token_hex_32

# ── Database ──────────────────────────────────────────────────────────
# Dev:
SQLALCHEMY_DATABASE_URI=sqlite:///app.db
# Production PostgreSQL:
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@host:5432/tunedessays

# ── Redis (optional — app works without it in dev) ────────────────────
# REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# ── Email ─────────────────────────────────────────────────────────────
# Resend (recommended): EMAIL_HOST=smtp.resend.com, MAIL_USERNAME=resend, MAIL_PASSWORD=re_YOUR_KEY
# Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587, MAIL_USERNAME=you@gmail.com, MAIL_PASSWORD=app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=info@tunedessays.com

# ── Frontend / CORS ───────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# ── Payment (add when ready) ──────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...

# ── AI Insights (optional — rule-based works without key) ─────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Dev convenience ───────────────────────────────────────────────────
# Set False to skip email verification during local testing
REQUIRE_EMAIL_VERIFICATION=False
